# =============================================================================
# Investor Intelligence Suite - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# =============================================================================

# =============================================================================
# API Gateway (Phase 4 Integration)
# =============================================================================
API_GATEWAY_URL=http://localhost:8000
API_VERSION=v1
API_KEY=your_api_key_here

# =============================================================================
# Phase 5 Frontend Configuration
# =============================================================================
REACT_APP_API_GATEWAY_URL=http://localhost:8000
REACT_APP_API_VERSION=v1
REACT_APP_API_KEY=your_api_key_here
REACT_APP_APP_NAME="Investor Intelligence Suite"

# =============================================================================
# Pillar A: Smart-Sync Knowledge Base (RAG)
# =============================================================================
# Pinecone Vector DB
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=your_pinecone_environment
PINECONE_INDEX_NAME=investor-kb

# OpenRouter for LLM
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# BGE Embeddings
BGE_MODEL_PATH=BAAI/bge-large-en-v1.5

# =============================================================================
# Pillar B: Insight-Driven Agent Optimization
# =============================================================================
# Groq for Theme Classification
GROQ_API_KEY=your_groq_api_key
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Weekly Pulse Configuration
WEEKLY_PULSE_WORD_LIMIT=250
WEEKLY_PULSE_ACTION_COUNT=3

# =============================================================================
# Pillar C: Super-Agent MCP Workflow
# =============================================================================
# Sarvam AI for Voice (STT/TTS)
SARVAM_API_KEY=your_sarvam_api_key
SARVAM_BASE_URL=https://api.sarvam.ai

# Silero VAD
SILERO_MODEL_PATH=silero_vad

# MCP Servers
MCP_CALENDAR_SERVER_URL=http://localhost:3001
MCP_SERVER_URL=https://ashishsankhua-google-docs-gmail-mcp-server.hf.space
MCP_EMAIL_SERVER_URL=http://localhost:3002
MCP_TIMEOUT_S=10

# Fixed Google Meet URL for all bookings
GOOGLE_MEET_URL=https://meet.google.com/mgq-xoua-egx?authuser=0

# Google Services (for Calendar Hold & Email Draft)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# Tracking Google Doc (HITL)
GOOGLE_TRACKING_DOC_ID=your_tracking_doc_id

# Advisor email for HITL notifications and email drafts
ADVISOR_EMAIL=advisor@yourdomain.com

# =============================================================================
# Safety & Compliance
# =============================================================================
# PII Redaction
ENABLE_PII_REDACTION=true
REDACTED_TOKEN=[REDACTED]

# =============================================================================
# Database (for Phase 4 State Management)
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/investor_suite
REDIS_URL=redis://localhost:6379

# =============================================================================
# Deployment
# =============================================================================
NODE_ENV=development
PORT=3000
VERCEL_TOKEN=your_vercel_token

# =============================================================================
# Testing & Evaluation
# =============================================================================
EVAL_GOLDEN_DATASET_PATH=./data/golden_dataset.json
RAG_FAITHFULNESS_THRESHOLD=0.9
SAFETY_EVAL_PASS_THRESHOLD=1.0
